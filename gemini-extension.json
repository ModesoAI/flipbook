{
  "name": "flipbook",
  "version": "1.0.8",
  "description": "High-performance 3D scroll-driven narrative engine",
  "mcpServers": {
    "flipbook-server": {
      "command": "bash",
      "args": [
        "${extensionPath}/run.sh",
        "--workspace",
        "${workspacePath}"
      ],
      "cwd": "${extensionPath}"
    }
  },
  "contextFileName": "GEMINI.md",
  "settings": [
    {
      "name": "Gemini API Key",
      "description": "API Key for Nano Banana 2 and Veo 3.1 generation",
      "envVar": "GEMINI_API_KEY",
      "sensitive": false
    }
  ]
}

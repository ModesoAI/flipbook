{
  "name": "flipbook",
  "version": "1.0.1",
  "description": "High-performance 3D scroll-driven narrative engine",
  "runtime": "python",
  "entrypoint": "main.py",
  "mcpServers": {
    "flipbook": {
      "command": "${extensionPath}/.venv/bin/python",
      "args": [
        "${extensionPath}/main.py"
      ],
      "cwd": "${extensionPath}"
    }
  },
  "dependencies": {
    "python": ">=3.10",
    "pip": [
      "mcp",
      "fastmcp",
      "requests",
      "python-dotenv"
    ]
  },
  "settings": [
    {
      "name": "Gemini API Key",
      "description": "API Key for Nano Banana 2 and Veo 3.1 generation",
      "envVar": "GEMINI_API_KEY",
      "sensitive": false
    }
  ]
}

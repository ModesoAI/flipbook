{
  "name": "flipbook",
  "version": "1.0.0",
  "description": "High-performance 3D scroll-driven narrative engine",
  "mcpServers": {
    "flipbook": {
      "command": "python3",
      "args": [
        "${extensionPath}/main.py"
      ],
      "cwd": "${extensionPath}"
    }
  },
  "settings": [
    {
      "name": "Gemini API Key",
      "description": "API Key for Nano Banana 2 and Veo 3.1 generation",
      "envVar": "GEMINI_API_KEY",
      "sensitive": false
    }
  ]
}
